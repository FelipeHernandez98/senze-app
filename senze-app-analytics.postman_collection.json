  "item": [
    {
      "name": "Auth Helper",
      "item": [
        {
          "name": "POST /users/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login responde token', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.token).to.exist;",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"andres\",\n  \"password\": \"Secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Ejecuta esta request primero para guardar el JWT en {{token}}."
          },
          "response": []
        }
      ]
    },
